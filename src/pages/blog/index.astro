---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import FormattedDate from "@/components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const bgClasses = [
  "bg-pgreen rounded-full",
  "bg-pblue rounded-2xl",
  "bg-ppink",
  "bg-pyellow rounded-md",
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container mx-auto md:px-10 py-20">
      <section class="flex flex-col items-center text-center gap-4">
        <p class="text-pblack">From the desk of Parth</p>
        <h2 class="text-4xl font-bold">Distilled Articles</h2>
        <ul class="flex flex-wrap max-w-[940px] mx-auto justify-center md:justify-start gap-8 py-20">
          {
            posts.map((post, i) => (
              <li class="w-72 text-left rounded-3xl border-1 border-black shadow-card group hover:shadow-hover transition px-4 py-6 flex flex-col gap-6">
                <a aria-label={post.data.title} href={`/blog/${post.id}/`} class="flex flex-col gap-4">
                  <div class={`${bgClasses[i % bgClasses.length]} text-4xl p-2 self-start border-1 border-black shadow-card1 group-hover:shadow-card transition`}>
                    <Icon name={post.data.icon} />
                  </div>
                  <h2 class="text-xl font-semibold">{post.data.title}</h2>
                  <p class="date -mt-4 text-sm font-light">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </a>
                <div set:html={post.data.description} />
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
