---
import { Icon } from "astro-icon/components";
---

<style>
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.4); }
  }
  .live-dot {
    animation: pulse-dot 1.4s ease-in-out infinite;
  }
</style>

<section
  class="pt-10 pb-20 md:py-20 flex md:flex-row flex-col px-6 md:px-0 gap-6 md:gap-0 self-center max-w-5xl mx-auto"
>
  <!-- Left column -->
  <div class="flex flex-col gap-6 justify-start items-start md:w-1/2">
    <h1 class="text-pblack" data-anim="hero-small">Tired of boring team building events?</h1>
    <p class="text-5xl md:text-6xl font-black font-playfair text-black" data-anim="hero-headline">A quiz night your team will love</p>
    <p data-anim="hero-sub">
      Level up your teams while having fun.
    </p>
    <a
      href="#contact"
      arial-label="Organise Quiz"
      data-anim="hero-btn"
      class="bg-brand-accent text-white px-5 py-3 border-1 border-black rounded-lg shadow-card hover:shadow-hover transition"
    >
      Organise Quiz
    </a>
  </div>

  <!-- Right column: image + floating elements (desktop only floats, mobile is clean) -->
  <div class="md:w-1/2 flex items-center justify-center md:justify-end md:p-10 group">

    <!-- Mobile: clean image, no floating badges -->
    <div class="md:hidden relative w-60 mt-4">
      <!-- LIVE badge -->
      <div class="absolute -top-4 right-0 z-20 flex items-center gap-1.5 bg-white border-1 border-black rounded-full px-2.5 py-1 shadow-card text-xs font-semibold">
        <span class="live-dot w-2 h-2 rounded-full bg-red-500 inline-block"></span>
        LIVE
      </div>
      <div class="h-80 w-60 overflow-hidden rounded-2xl border-3 border-black shadow-card transition">
        <img
          class="w-full h-full object-cover transition"
          style="object-position: 40% 0%"
          src="/parth.png"
          alt="Parth Sharma in Tbilisi"
        />
      </div>
    </div>

    <!-- Desktop: full floating layout -->
    <div class="hidden md:block relative">
      <!-- Name badge -->
      <div
        class="absolute text-nowrap flex items-center gap-4 -bottom-12 right-0 pr-4 bg-pgreen pl-1 z-10 shadow-card1 group-hover:shadow-card transition rounded-full border-3 border-black"
      >
        <Icon name="beach" />
        <p>Parth Sharma</p>
      </div>

      <!-- LIVE badge -->
      <div class="absolute -top-10 right-0 z-20 flex items-center gap-2 bg-white border-1 border-black rounded-full px-3 py-1 shadow-card text-sm font-semibold">
        <span class="live-dot w-2.5 h-2.5 rounded-full bg-red-500 inline-block"></span>
        LIVE
      </div>

      <!-- Answer card A (correct) -->
      <div class="absolute -left-36 top-8 z-20 bg-pgreen border-1 border-black rounded-2xl px-3 py-2 shadow-card text-xs font-semibold w-36 flex items-center gap-2">
        <span class="text-base">✅</span>
        <span>A) The French Revolution</span>
      </div>

      <!-- Answer card B -->
      <div class="absolute -left-32 top-24 z-20 bg-white border-1 border-black rounded-2xl px-3 py-2 shadow-card text-xs font-semibold w-36 flex items-center gap-2">
        <span class="text-base">🔲</span>
        <span>B) The British Empire</span>
      </div>

      <!-- Mini leaderboard -->
      <div class="absolute -right-2 -bottom-28 z-20 bg-white border-1 border-black rounded-2xl px-4 py-3 shadow-card text-xs flex flex-col gap-1 w-52">
        <p class="font-bold text-sm mb-1">Leaderboard</p>
        <p>🥇 Team Marketing <span class="font-bold">2400</span></p>
        <p>🥈 Team Sales <span class="font-bold">2100</span></p>
        <p>🥉 Team Design <span class="font-bold">1800</span></p>
      </div>

      <!-- Image container -->
      <div class="h-80 w-60 overflow-hidden relative -mt-30 rounded-2xl border-3 border-black shadow-card group-hover:shadow-hover transition">
        <img
          class="w-full h-full object-cover group-hover:scale-105 transition"
          style="object-position: 40% 0%"
          src="/parth.png"
          alt="Parth Sharma in Tbilisi"
        />
      </div>
    </div>

  </div>
</section>
